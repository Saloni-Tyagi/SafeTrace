<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <title>Edit Contact</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!-- SafeTrace CSS -->
    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

    <nav class="navbar">

        <div class="container">

            <span class="navbar-brand">
                🛡 SafeTrace
            </span>

            <a href="/contacts" class="btn btn-outline-light">
                Back
            </a>

        </div>

    </nav>

    <div class="container mt-5">

        <h2 class="page-title">
            ✏ Edit Emergency Contact
        </h2>

        <p class="page-subtitle">
            Update your trusted contact information.
        </p>

        <div class="card p-4">

            <form action="/contacts/edit/<%= contact._id %>" method="POST">

                <div class="mb-3">

                    <label class="form-label">
                        Name
                    </label>

                    <input
                        type="text"
                        name="name"
                        class="form-control"
                        value="<%= contact.name %>"
                        required>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Phone Number
                    </label>

                    <input
                        type="text"
                        name="phone"
                        class="form-control"
                        value="<%= contact.phone %>"
                        required>

                </div>

                <div class="mb-4">

                    <label class="form-label">
                        Relation
                    </label>

                    <input
                        type="text"
                        name="relation"
                        class="form-control"
                        value="<%= contact.relation %>"
                        required>

                </div>

                <button class="btn btn-primary">

                    <i class="bi bi-check-circle"></i>

                    Update Contact

                </button>

            </form>

        </div>

    </div>

</body>

</html>