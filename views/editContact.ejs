<!DOCTYPE html>
<html>

<head>
    <title>Edit Contact</title>
</head>

<body>

<h2>Edit Contact</h2>

<form action="/contacts/update/<%= contact._id %>" method="POST">

<input
type="text"
name="name"
value="<%= contact.name %>"
required>

<input
type="text"
name="phone"
value="<%= contact.phone %>"
required>

<input
type="text"
name="relation"
value="<%= contact.relation %>"
required>

<button type="submit">
Update Contact
</button>

</form>

<br>

<a href="/contacts">
Back
</a>

</body>

</html>