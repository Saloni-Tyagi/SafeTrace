<!DOCTYPE html>
<html>

<head>
    <title>SafeTrace Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<div class="container mt-5">

    <h2 class="mb-4">🛡️ SafeTrace Dashboard</h2>

    <div class="list-group">

        <a href="/complaint" class="list-group-item list-group-item-action">
            🚨 Report Complaint
        </a>

        <a href="/my-complaints" class="list-group-item list-group-item-action">
            📋 My Complaints
        </a>

        <a href="/contacts" class="list-group-item list-group-item-action">
            👥 Manage Emergency Contacts
        </a>

    </div>

    <button
        id="sosBtn"
        class="btn btn-danger btn-lg w-100 mt-4">
        🚨 SOS EMERGENCY
    </button>

    <div id="status" class="mt-3"></div>

    <a href="/logout" class="btn btn-secondary mt-4">
        Logout
    </a>

</div>

<script>

const sosBtn = document.getElementById("sosBtn");

sosBtn.addEventListener("click", () => {

    if (!navigator.geolocation) {
        alert("Geolocation is not supported.");
        return;
    }

    navigator.geolocation.getCurrentPosition(

        async (position) => {

            const latitude = position.coords.latitude;
            const longitude = position.coords.longitude;

            const response = await fetch("/sos", {

                method: "POST",

                headers: {
                    "Content-Type": "application/json"
                },

                body: JSON.stringify({
                    latitude,
                    longitude
                })

            });

            const data = await response.json();

            document.getElementById("status").innerHTML = `
                <div class="alert alert-success">
                    ${data.message}
                </div>
            `;

        },

        () => {
            alert("Location permission denied.");
        }

    );

});

</script>

</body>
</html>