<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>SafeTrace Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<nav class="navbar px-4">

    <span class="navbar-brand">
        🛡️ SafeTrace
    </span>

    <a href="/logout" class="btn btn-outline-light">
        Logout
    </a>

</nav>

<div class="container mt-5">

    <h2>Welcome 👋</h2>

    <p class="text-muted">
        Your personal safety dashboard
    </p>

    <div class="row g-4 mt-2">

        <div class="col-md-6">
            <a href="/complaint" style="text-decoration:none;color:black;">
                <div class="card p-4">
                    <i class="bi bi-exclamation-triangle-fill"></i>

                    <h4 class="mt-3">
                        Report Complaint
                    </h4>

                    <p>Report suspicious vehicles instantly.</p>

                </div>
            </a>
        </div>

        <div class="col-md-6">
            <a href="/my-complaints" style="text-decoration:none;color:black;">
                <div class="card p-4">

                    <i class="bi bi-file-earmark-text-fill"></i>

                    <h4 class="mt-3">
                        My Complaints
                    </h4>

                    <p>View all submitted complaints.</p>

                </div>
            </a>
        </div>

        <div class="col-md-6">
            <a href="/contacts" style="text-decoration:none;color:black;">
                <div class="card p-4">

                    <i class="bi bi-people-fill"></i>

                    <h4 class="mt-3">
                        Emergency Contacts
                    </h4>

                    <p>Manage trusted contacts.</p>

                </div>
            </a>
        </div>

        <div class="col-md-6">

            <div class="card sos-card p-4">

                <h2>🚨 Emergency SOS</h2>

                <p>
                    Press only if you need immediate help.
                </p>

                <button
                    id="sosBtn"
                    class="btn btn-light">

                    🚨 SOS NOW

                </button>

                <div id="status" class="mt-3"></div>

            </div>

        </div>

        <div class="col-md-6">
            <a href="/alerts" style="text-decoration:none;color:black;">
                <div class="card p-4">

                    <i class="bi bi-clock-history"></i>

                    <h4 class="mt-3">
                        Alert History
                    </h4>

                    <p>
                        View all your previous SOS alerts.
                    </p>

                </div>
            </a>
        </div>

    </div>

</div>

<script>

const btn = document.getElementById("sosBtn");
const status = document.getElementById("status");

btn.addEventListener("click", () => {

    if (!navigator.geolocation) {
        status.innerHTML = `
            <div class="alert alert-danger">
                Geolocation is not supported by your browser.
            </div>
        `;
        return;
    }

    btn.innerHTML = `
        <span class="spinner-border spinner-border-sm"></span>
        Getting Location...
    `;
    btn.disabled = true;

    navigator.geolocation.getCurrentPosition(

        async (position) => {

            const latitude = position.coords.latitude;
            const longitude = position.coords.longitude;

            btn.innerHTML = `
                <span class="spinner-border spinner-border-sm"></span>
                Sending SOS...
            `;

            try {

                const response = await fetch("/sos", {

                    method: "POST",

                    headers: {
                        "Content-Type": "application/json"
                    },

                    body: JSON.stringify({
                        latitude,
                        longitude
                    })

                });

                const data = await response.json();

                const now = new Date().toLocaleString();

                status.innerHTML = `
                <div class="alert alert-success mt-3 shadow-sm rounded-3">
                    <h5>✅ Emergency Alert Sent</h5>
                    <p class="mb-1">
                        Your current location has been recorded successfully.
                    </p>
                    <small><strong>Time:</strong> ${now}</small>
                </div>
                `;

                btn.innerHTML = "🚨 SOS Sent";
                btn.classList.remove("btn-light");
                btn.classList.add("btn-success");

            } catch (err) {

                status.innerHTML = `
                    <div class="alert alert-danger mt-3">
                        Failed to send SOS.
                    </div>
                `;

                btn.innerHTML = "🚨 Try Again";
                btn.disabled = false;

            }

        },

        () => {

            status.innerHTML = `
                <div class="alert alert-warning mt-3">
                    Location permission denied.
                </div>
            `;

            btn.innerHTML = "🚨 SOS NOW";
            btn.disabled = false;

        }

    );

});


</script>

</body>

</html>