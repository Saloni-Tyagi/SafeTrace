<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Emergency Contacts</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!-- SafeTrace CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <nav class="navbar">
        <div class="container">

            <span class="navbar-brand">
                🛡 SafeTrace
            </span>

            <a href="/dashboard" class="btn btn-outline-light">
                Dashboard
            </a>

        </div>
    </nav>

    <div class="container mt-5">

        <h2 class="page-title">
            👥 Emergency Contacts
        </h2>

        <p class="page-subtitle">
            Manage your trusted contacts.
        </p>

        <!-- Add Contact -->

        <div class="card p-4 mb-4">

            <form action="/contacts" method="POST">

                <div class="row g-3">

                    <div class="col-md-4">
                        <input
                            type="text"
                            name="name"
                            class="form-control"
                            placeholder="Name"
                            required>
                    </div>

                    <div class="col-md-4">
                        <input
                            type="text"
                            name="phone"
                            class="form-control"
                            placeholder="Phone Number"
                            required>
                    </div>

                    <div class="col-md-4">
                        <input
                            type="text"
                            name="relation"
                            class="form-control"
                            placeholder="Relation"
                            required>
                    </div>

                </div>

                <button class="btn btn-primary mt-4">

                    <i class="bi bi-plus-circle"></i>

                    Add Contact

                </button>

            </form>

        </div>

        <!-- Contacts Table -->

        <div class="card p-4">

            <table class="table table-hover align-middle">

                <thead>

                    <tr>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Relation</th>
                        <th>Actions</th>
                    </tr>

                </thead>

                <tbody>

                    <% contacts.forEach(contact => { %>

                        <tr>

                            <td>
                                <%= contact.name %>
                            </td>

                            <td>
                                <%= contact.phone %>
                            </td>

                            <td>
                                <%= contact.relation %>
                            </td>

                            <td>

                                <a
                                    href="/contacts/edit/<%= contact._id %>"
                                    class="btn btn-warning btn-sm">

                                    <i class="bi bi-pencil-square"></i>

                                    Edit

                                </a>

                                <a
                                    href="/contacts/delete/<%= contact._id %>"
                                    class="btn btn-danger btn-sm">

                                    <i class="bi bi-trash"></i>

                                    Delete

                                </a>

                            </td>

                        </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</body>

</html>