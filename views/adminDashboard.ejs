<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<nav class="navbar">

    <div class="container">

        <span class="navbar-brand">
            🛡 SafeTrace Admin
        </span>

        <a href="/dashboard" class="btn btn-outline-light">
            Dashboard
        </a>

    </div>

</nav>

<div class="container mt-5">

    <h2 class="page-title">
        📊 Admin Dashboard
    </h2>

    <p class="page-subtitle">
        Manage complaints and monitor platform activity.
    </p>

    <div class="row g-4 mb-4">

        <div class="col-md-4">

            <div class="card p-4 text-center">

                <i class="bi bi-people-fill display-5 text-primary"></i>

                <h3 class="mt-3">
                    <%= users.length %>
                </h3>

                <p>Total Users</p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card p-4 text-center">

                <i class="bi bi-exclamation-triangle-fill display-5 text-danger"></i>

                <h3 class="mt-3">
                    <%= complaints.length %>
                </h3>

                <p>Total Complaints</p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card p-4 text-center">

                <i class="bi bi-bell-fill display-5 text-warning"></i>

                <h3 class="mt-3">
                    <%= alerts.length %>
                </h3>

                <p>SOS Alerts</p>

            </div>

        </div>

    </div>

</div>

</body>

</html>