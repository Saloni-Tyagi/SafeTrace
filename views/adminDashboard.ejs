<!DOCTYPE html>
<html>
<head>
    <title>Report Complaint</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5>Total Complaints</h5>
                    <h2><%= totalComplaints %></h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5>Pending</h5>
                    <h2><%= pendingComplaints %></h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5>In Progress</h5>
                    <h2><%= inProgressComplaints %></h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5>Resolved</h5>
                    <h2><%= resolvedComplaints %></h2>
                </div>
            </div>
        </div>
    </div>
</div>

<hr>

<% complaints.forEach((complaint) => { %>

    <div>
        <h3><%= complaint.title %></h3>

        <p><%= complaint.description %></p>

        <p>User: <%= complaint.user.name %></p>

        <p>Email: <%= complaint.user.email %></p>

        <p>Status: <%= complaint.status %></p>

        <p>Status: <%= complaint.status %></p>

        <p>Submitted On: <%= complaint.createdAt.toLocaleString() %></p>

        <p>Last Updated: <%= complaint.updatedAt ? complaint.updatedAt.toLocaleString() : "Not Updated Yet" %></p>

        <form action="/admin/complaints/<%= complaint._id %>/status" method="POST">

            <select name="status">
                <option value="Pending" <%= complaint.status === "Pending" ? "selected" : "" %>>
                    Pending
                </option>

                <option value="In Progress" <%= complaint.status === "In Progress" ? "selected" : "" %>>
                    In Progress
                </option>

                <option value="Resolved" <%= complaint.status === "Resolved" ? "selected" : "" %>>
                    Resolved
                </option>
            </select>

            <button type="submit">Update</button>

        </form>

        <form action="/admin/complaints/<%= complaint._id %>/delete" method="POST">
            <button type="submit">Delete</button>
        </form>

        <hr>
    </div>
    
<% }) %>

</body>
</html>